# Токен Telegram-бота.
TELEGRAM_TOKEN=

# Провайдер модели: ollama | openrouter | openai.
MODEL_PROVIDER=openrouter

# OpenAI-compatible endpoint.
# Если не задан, подставится автоматически по MODEL_PROVIDER.
OPENAI_BASE_URL=

# API-ключ.
# Для ollama можно оставить пустым.
OPENAI_API_KEY=

# Модель.
# Если не задана, подставится автоматически по MODEL_PROVIDER.
MODEL_NAME=

# Эмбеддинги: auto | local | openai_compatible.
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL_NAME=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=64

# Путь к локальной базе Chroma.
CHROMA_PATH=./chroma_db

# Имя коллекции в Chroma.
COLLECTION_NAME=sanitary_goods

# Сколько чанков возвращать из RAG-поиска.
TOP_K=5

# (Опционально) Tavily Web Search API.
TAVILY_API_KEY=

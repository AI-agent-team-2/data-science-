# Токен Telegram-бота.
TELEGRAM_TOKEN=

# Провайдер модели: openrouter | openai.
MODEL_PROVIDER=openrouter

# OpenAI-compatible URL.
# Если не задан, будет выбран автоматически по MODEL_PROVIDER.
OPENAI_BASE_URL=

# API-ключ LLM.
OPENAI_API_KEY=

# Модель.
# Если не задана, подставится автоматически по MODEL_PROVIDER.
MODEL_NAME=

# Настройки эмбеддингов (опционально, по умолчанию используются ключ/URL LLM).
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Инфраструктурные пути (могут отличаться между окружениями).
CHROMA_PATH=./chroma_db
HISTORY_DB_PATH=./history.db
STARTUP_INDEX_MODE=if_empty

# Ключ внешнего веб-поиска (опционально).
TAVILY_API_KEY=

# Langfuse observability (опционально).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_ENABLED=false

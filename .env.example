# Токен Telegram-бота.
TELEGRAM_TOKEN=

# Провайдер модели: openrouter | openai.
MODEL_PROVIDER=openrouter

# OpenAI-compatible URL.
# Если не задан, будет выбран автоматически по MODEL_PROVIDER.
OPENAI_BASE_URL=

# API-ключ.
OPENAI_API_KEY=

# Модель.
# Если не задана, подставится автоматически по MODEL_PROVIDER.
MODEL_NAME=

# Настройки эмбеддингов (OpenAI-compatible).
EMBEDDING_MODEL_NAME=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=64

# Путь к локальной базе Chroma.
CHROMA_PATH=./chroma_db

# Имя коллекции в Chroma.
COLLECTION_NAME=sanitary_goods

# Сколько чанков возвращать из RAG-поиска.
TOP_K=6

# Параметры чанкинга для индексации RAG.
CHUNK_SIZE=900
CHUNK_OVERLAP=140

# Параметры хранения истории диалогов (SQLite).
HISTORY_DB_PATH=./history.db
HISTORY_MAX_MESSAGES=24
HISTORY_TTL_DAYS=30

# (Опционально) ключ Tavily Web Search API.
TAVILY_API_KEY=

# Langfuse observability (опционально).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_ENABLED=false

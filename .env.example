# Токен Telegram-бота.
TELEGRAM_TOKEN=

# Провайдер модели: openrouter | openai.
MODEL_PROVIDER=openrouter

# OpenAI-compatible URL.
# Если не задан, будет выбран автоматически по MODEL_PROVIDER.
OPENAI_BASE_URL=

# API-ключ LLM.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Модель.
# Если не задана, подставится автоматически по MODEL_PROVIDER.
MODEL_NAME=

# Настройки эмбеддингов (опционально, по умолчанию используются ключ/URL LLM).
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL_NAME=

# Инфраструктурные пути (могут отличаться между окружениями).
CHROMA_PATH=./chroma_db
HISTORY_DB_PATH=./history.db
STARTUP_INDEX_MODE=if_empty
MODEL_MAX_RETRIES=2
INVOKE_MAX_WORKERS=8
INVOKE_MAX_QUEUE=64
# (Опционально) отдельные лимиты для пулов внешних вызовов.
# Если не заданы, model/tool делят общий INVOKE_MAX_WORKERS.
# INVOKE_MODEL_MAX_WORKERS=2
# INVOKE_TOOL_MAX_WORKERS=6
# INVOKE_MODEL_MAX_QUEUE=64
# INVOKE_TOOL_MAX_QUEUE=64

# Circuit breaker для LLM API (защита от каскадных отказов при падениях/429/5xx).
MODEL_CIRCUIT_BREAKER_ENABLED=true
MODEL_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
MODEL_CIRCUIT_BREAKER_COOLDOWN_SEC=30
MODEL_CIRCUIT_BREAKER_HALF_OPEN_SUCCESS_THRESHOLD=1

# Ключ внешнего веб-поиска (опционально).
TAVILY_API_KEY=

# Файловый кэш web-поиска (.web_cache/ в корне проекта; в Docker: /app/.web_cache).
# WEB_CACHE_ENABLED=true
# WEB_CACHE_TTL_HOURS=24

# Безопасность web API.
# Обязателен для админских эндпоинтов /api/history, /api/clear (передается в заголовке X-API-Key).
WEB_API_KEY=
# Список разрешенных origin через запятую.
WEB_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# (Опционально) allowlist доменов для web-поиска, через запятую.
WEB_TRUSTED_DOMAINS=

# Langfuse observability (опционально).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_ENABLED=false

# RAG thresholds / scoring
# MIN_RAG_SCORE=0.2
# PRODUCT_EXACT_SKU_BASE_SCORE=100.0
# PRODUCT_EXACT_SKU_PER_MATCH_SCORE=25.0
# RAG_OVERLAP_BONUS_WEIGHT=0.03
# MAX_TOTAL_TOKEN_BUDGET=100000
# MAX_USER_TOKEN_BUDGET=20000
# TOKEN_BUDGET_WARNING_THRESHOLD=0.8
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW_SEC=60
